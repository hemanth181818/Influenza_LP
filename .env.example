# --- Airtable (lead capture) ---
AIRTABLE_TOKEN=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE_NAME=
AIRTABLE_EMAIL_FIELD=Email

# --- Brevo (welcome email) ---
# v3 API key from Brevo > SMTP & API > API Keys tab. Starts with `xkeysib-`.
# Do NOT use an SMTP credential (`xsmtpsib-`) - the v3 transactional endpoint
# rejects those with 401.
BREVO_API_KEY=
# Sender email. Must be a verified sender / verified domain in Brevo.
BREVO_SENDER_EMAIL=
# Display name shown in the inbox. Defaults to "Influenza" if blank.
BREVO_SENDER_NAME=Influenza
# Optional: replies go here. Falls back to the sender if blank.
BREVO_REPLY_TO=
# Optional: CC address copied on every welcome email (manual + automated).
BREVO_CC=

# --- Questionnaire (CTA link inside the welcome email) ---
# Defaults to the Issue 01 Tally form if blank.
QUESTIONNAIRE_URL=https://tally.so/r/EkaLZA

# --- CRM dashboard (/crm) ---
# Shared password to access the internal lead pipeline at /crm.
CRM_PASSWORD=
# Long random string used to sign session cookies. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
CRM_SESSION_SECRET=

# CRM Airtable field names. These default to the names below if left blank -
# only set them if your column headers differ. See CRM_SETUP.md.
AIRTABLE_NAME_FIELD=Name
AIRTABLE_PHONE_FIELD=Phone
AIRTABLE_COMPANY_FIELD=Company
AIRTABLE_STAGE_FIELD=Stage
AIRTABLE_PLATFORM_FIELD=Platform
AIRTABLE_SOURCE_FIELD=Source
AIRTABLE_NOTES_FIELD=Notes
AIRTABLE_NEXT_ACTION_FIELD=Next Action
AIRTABLE_NEXT_ACTION_NOTE_FIELD=Next Action Note
AIRTABLE_LAST_CONTACTED_FIELD=Last Contacted
AIRTABLE_ACTIVITY_FIELD=Activity Log
